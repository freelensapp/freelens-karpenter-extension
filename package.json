{
  "name": "@freelensapp/karpenter-extension",
  "version": "1.0.1-0",
  "description": "Karpenter extension",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freelensapp/freelens-karpenter-extension.git",
    "directory": "."
  },
  "main": "out/main/index.js",
  "renderer": "out/renderer/index.js",
  "files": [
    "out/**/*"
  ],
  "engines": {
    "node": ">= 22.14.0",
    "freelens": "^1.3.0"
  },
  "copyright": "© 2025-2026 Freelens Authors",
  "license": "MIT",
  "author": {
    "name": "Freelens Authors",
    "email": "freelens@freelens.app"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "biome": "corepack pnpm dlx @biomejs/biome@2.1.1",
    "biome:check": "corepack pnpm biome check",
    "biome:fix": "corepack pnpm biome check --fix",
    "biome:migrate": "corepack pnpm biome migrate --write",
    "prebuild": "corepack pnpm type:check",
    "build": "electron-vite build",
    "build:production": "VITE_PRESERVE_MODULES=false electron-vite build",
    "bump-version": "corepack pnpm version --no-commit-hooks --no-git-tag-version",
    "clean": "corepack pnpm dlx rimraf@6.0.1 binaries dist static/build",
    "clean:node_modules": "corepack pnpm dlx rimraf@6.0.1 node_modules",
    "knip": "corepack pnpm dlx knip@5.88.1 --dependencies",
    "knip:check": "corepack pnpm \"/^knip:(development|production)\\$/\"",
    "knip:development": "corepack pnpm knip",
    "knip:production": "corepack pnpm knip --production --strict",
    "lint": "corepack pnpm biome:check",
    "lint:check": "corepack pnpm \"/^(biome|prettier):check\\$/\"",
    "lint:fix": "corepack pnpm biome:fix",
    "type:check": "tsc --noEmit -p tsconfig.json --composite false",
    "build-extension": "corepack pnpm build && pnpm pack"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@freelensapp/extensions": "^1.3.0",
    "@types/node": "^22.15.24",
    "@types/react": "^17.0.87",
    "@vitejs/plugin-react": "^4.5.0",
    "electron-vite": "^3.1.0",
    "typescript": "5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-external": "^6.2.2"
  },
  "keywords": [
    "extension",
    "freelensapp",
    "lens",
    "openlens",
    "freelens"
  ],
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@ogre-tools/injectable": "^17.11.1",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "mobx": "^6.13.7",
    "mobx-react": "^9.2.0",
    "moment": "^2.30.1"
  }
}
