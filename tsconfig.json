{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["*.ts", "src/**/*"],
  "exclude": [
    "src/endpoints"
  ],
  "compilerOptions": {
    "composite": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "electron-vite/node"],
    "experimentalDecorators": true
  }
}
